NODE_ENV=development
PORT=3001

WEB_APP_URL=http://localhost:8081
API_BASE_URL=http://api:3001/api
VITE_API_URL=/api

SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=localhost

POSTGRES_PASSWORD=replace_password
BOT_API_KEY=replace_with_a_long_random_secret_at_least_32_chars
DATABASE_URL=postgresql://launcherbot:replace_password@postgres:5432/launcher_bot

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_PUBLIC_KEY=your_discord_application_public_key
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/callback
DISCORD_BOT_TOKEN=your_discord_bot_token

USE_MOCK_DISCORD_OAUTH=false
BOT_MOCK_MODE=false

DISCORD_SYNC_COMMANDS_ON_BOOT=true
DISCORD_DEV_GUILD_ID=
