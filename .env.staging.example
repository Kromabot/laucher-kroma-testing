NODE_ENV=production
PORT=3001

WEB_APP_URL=https://staging.kromabot.com
API_BASE_URL=https://staging.kromabot.com/api
VITE_API_URL=/api

SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true

POSTGRES_PASSWORD=replace_password
BOT_API_KEY=replace_with_a_long_random_secret_at_least_32_chars
DATABASE_URL=postgresql://launcherbot:replace_password@postgres:5432/launcher_bot_staging

API_IMAGE=ghcr.io/your-org/launcher-bot-api:staging
BOT_IMAGE=ghcr.io/your-org/launcher-bot-bot:staging
WEB_IMAGE=ghcr.io/your-org/launcher-bot-web:staging

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_PUBLIC_KEY=your_discord_application_public_key
DISCORD_REDIRECT_URI=https://staging.kromabot.com/api/auth/callback
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_SYNC_COMMANDS_ON_BOOT=true
DISCORD_DEV_GUILD_ID=

USE_MOCK_DISCORD_OAUTH=false
BOT_MOCK_MODE=true

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
