# Example local .env for development
# Copy to .env and fill values: cp .env.local.example .env

# App URLs
WEB_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001/api
VITE_API_URL=http://localhost:5173

# API
PORT=3001
BOT_API_KEY=replace_with_dev_bot_api_key_32chars_min
DATABASE_URL=postgresql://launcherbot:replace_password@127.0.0.1:5432/launcher_bot

# Twitch EventSub (register app at https://dev.twitch.tv)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# secret used to verify EventSub signatures (choose a random string)
TWITCH_EVENTSUB_SECRET=replace_with_random_secret
# public callback URL (must be HTTPS in production)
TWITCH_CALLBACK_URL=http://your-public-host/api/twitch/eventsub

# Internal bot URL reachable by API (docker service name in production)
BOT_INTERNAL_URL=http://bot:3001

# YouTube PubSubHubbub / Notifications
YOUTUBE_CALLBACK_URL=http://your-public-host/api/streams/youtube/callback
YOUTUBE_HUB_SECRET=replace_with_random_secret

# Facebook / Instagram (Graph API webhooks)
FB_APP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=replace_with_random_token
FB_CALLBACK_URL=https://your-public-host/api/streams/facebook/callback

# Other providers (placeholders)
KICK_CALLBACK_URL=https://your-public-host/api/streams/kick/callback
TROVO_CALLBACK_URL=https://your-public-host/api/streams/trovo/callback
NIMOTV_CALLBACK_URL=https://your-public-host/api/streams/nimo/callback
TIKTOK_CALLBACK_URL=https://your-public-host/api/streams/tiktok/callback


# Discord (use mock mode if you don't have real tokens)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/callback
DISCORD_BOT_TOKEN=

# Development flags
USE_MOCK_DISCORD_OAUTH=true
BOT_MOCK_MODE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=localhost

# Feature flags / sync
DISCORD_SYNC_COMMANDS_ON_BOOT=false
FORCE_GUILD_SYNC=false
DISCORD_SYNC_GLOBAL_COMMANDS=false

# Stripe (use test keys only)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_test_replace
STRIPE_PREMIUM_PRICE_ID=price_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace

# Image overrides for docker compose (optional)
API_IMAGE=ghcr.io/fevereiro2/launcher-bot-api:staging
BOT_IMAGE=ghcr.io/fevereiro2/launcher-bot-bot:staging
WEB_IMAGE=ghcr.io/fevereiro2/launcher-bot-web:staging
